{
  "name": "@a2ui-sdk/solid",
  "version": "0.1.0",
  "description": "SolidJS implementation for rendering A2UI protocol",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./0.9": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "dev": "tsup src/index.ts --format esm --watch --dts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run"
  },
  "peerDependencies": {
    "solid-js": "^1.8.0"
  },
  "dependencies": {
    "@a2ui-sdk/types": "^0.4.0",
    "@a2ui-sdk/utils": "^0.4.0",
    "@kobalte/core": "^0.13.11",
    "@solidjs/start": "^1.3.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "flatpickr": "^4.6.13",
    "lucide-solid": "^1.11.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "eslint": "^8.55.0",
    "solid-js": "^1.8.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "vite": "^5.0.0",
  "vite-plugin-solid": "^2.11.0"
  },
  "keywords": [
    "solidjs",
    "a2ui",
    "sdk",
    "renderer",
    "typescript"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/KholiqAmrulloh/solid-a2ui"
  }
}
