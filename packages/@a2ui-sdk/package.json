{
  "name": "@a2ui-sdk/solid",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "peerDependencies": {
    "solid-js": "^1.8.0"
  },
  "devDependencies": {
    "solid-js": "^1.8.0",
    "tsup": "^8.5.1",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-solid": "^2.8.0"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --out-dir dist",
    "dev": "tsup src/index.ts --format esm --dts --watch --clean --out-dir dist",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ]
}